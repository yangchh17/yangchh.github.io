    .phase{display:grid;grid-template-columns:200px 1fr;gap:48px;padding:64px 0;border-bottom:1px solid var(--border);}
    .phase:last-child{border-bottom:none;}
    .phase-label-col{padding-top:4px;}
    .phase-num{font-family:'DM Mono',monospace;font-size:10px;color:var(--muted);letter-spacing:0.15em;text-transform:uppercase;margin-bottom:8px;}
    .phase-name{font-family:'Syne',sans-serif;font-size:22px;font-weight:700;color:var(--text);line-height:1.2;position:relative;}
    .phase-name::after{content:'';display:block;width:24px;height:2px;background:var(--accent);margin-top:12px;}
    .phase-body{display:flex;flex-direction:column;gap:20px;}
    .phase-body p{font-size:15px;color:var(--muted);line-height:1.85;}
    .phase-body p strong{color:var(--text);font-weight:500;}
    .callout{background:var(--surface);border:1px solid var(--border);border-left:3px solid var(--accent);border-radius:0 6px 6px 0;padding:20px 24px;font-size:14px;color:var(--muted);line-height:1.7;}
    .callout strong{color:var(--accent);font-family:'DM Mono',monospace;font-size:11px;letter-spacing:0.1em;text-transform:uppercase;display:block;margin-bottom:6px;}
    .outcome-stats{display:grid;grid-template-columns:repeat(3,1fr);gap:1px;background:var(--border);border:1px solid var(--border);border-radius:8px;overflow:hidden;margin-top:8px;}
    .outcome-stat{background:var(--surface);padding:28px 24px;}
    .outcome-value{font-family:'Syne',sans-serif;font-size:32px;font-weight:800;color:var(--accent);line-height:1;margin-bottom:6px;}
    .outcome-label{font-family:'DM Mono',monospace;font-size:11px;color:var(--muted);letter-spacing:0.06em;text-transform:uppercase;line-height:1.5;}
    .tech-stack{display:flex;flex-wrap:wrap;gap:8px;margin-top:8px;}
    .tech-pill{font-family:'DM Mono',monospace;font-size:11px;padding:5px 12px;border-radius:4px;background:var(--surface2);color:var(--text);border:1px solid var(--border);letter-spacing:0.04em;}
    .phase-subtitle{font-family:'DM Mono',monospace;font-size:11px;color:var(--accent);letter-spacing:0.12em;text-transform:uppercase;margin-bottom:4px;}
    .phase-divider{height:1px;background:var(--border);margin:8px 0 28px;}
    .case-nav{display:flex;justify-content:space-between;align-items:center;padding:48px;border-top:1px solid var(--border);max-width:900px;margin:0 auto;position:relative;z-index:1;}
    .case-nav a{font-family:'DM Mono',monospace;font-size:12px;color:var(--muted);text-decoration:none;letter-spacing:0.06em;display:flex;align-items:center;gap:8px;transition:color 0.2s;}
    .case-nav a:hover{color:var(--accent);}
    @media(max-width:768px){
      nav{padding:16px 24px;}
      .case-hero{padding:120px 24px 64px;}
      .case-content{padding:0 24px 64px;}
      .phase{grid-template-columns:1fr;gap:24px;}
      .phase-name::after{display:none;}
      .outcome-stats{grid-template-columns:1fr;}
      .case-nav{padding:32px 24px;}
    }

    /* ── PROJECT MAP ── */
    .project-map-section {
      position: relative;
      z-index: 1;
      max-width: 900px;
      margin: 0 auto;
      padding: 0 48px 0;
      border-bottom: 1px solid var(--border);
    }
    .map-label {
      font-family: 'DM Mono', monospace;
      font-size: 10px;
      color: var(--muted);
      letter-spacing: 0.15em;
      text-transform: uppercase;
      margin-bottom: 12px;
      padding-top: 48px;
    }
    .map-label span {
      color: var(--accent);
      margin-left: 8px;
    }
    .project-map-container {
      width: 100%;
      height: 340px;
      border-radius: 6px;
      border: 1px solid var(--border);
      overflow: hidden;
      margin-bottom: 48px;
    }
    .leaflet-popup-content-wrapper {
      background: var(--surface2, #241a14);
      color: var(--text, #f5ede8);
      border: 1px solid var(--border, #3d2318);
      border-radius: 6px;
      box-shadow: 0 8px 24px rgba(0,0,0,0.5);
    }
    .leaflet-popup-tip { background: var(--surface2, #241a14); }
    .leaflet-popup-content { font-family: 'DM Sans', sans-serif; font-size: 12px; line-height: 1.6; }
    .leaflet-popup-content b { font-family: 'Syne', sans-serif; color: #e85d3a; }
    @media(max-width:768px){
      .project-map-section { padding: 0 24px 0; }
      .project-map-container { height: 260px; }
    }
  </style>
</head>
<body>
  <nav>
    <a href="index.html" class="nav-logo">cy.gis</a>
    <a href="index.html" class="nav-back">← All Projects</a>
  </nav>

  <div class="case-hero">
    <div class="case-number">Project 03</div>
    <h1 class="case-title">Bioregional Atlas<br><span>Map Series</span></h1>
    <p class="case-summary">
      Producing a multi-theme printed map atlas to support Indigenous consultation processes
      and executive-level regional planning — translating complex environmental datasets
      into clear, decision-ready cartographic outputs.
    </p>
    <div class="case-meta">
      <div class="meta-item"><span class="meta-label">Domain</span><span class="meta-value">Environmental Planning</span></div>
      <div class="meta-item"><span class="meta-label">Output</span><span class="meta-value">Printed Atlas</span></div>
      <div class="meta-item"><span class="meta-label">Role</span><span class="meta-value">GIS Specialist</span></div>
      <div class="meta-item"><span class="meta-label">Region</span><span class="meta-value">Coastal BC</span></div>
    </div>
  </div>


  <!-- PROJECT MAP -->
  <div class="project-map-section">
    <div class="map-label">Spatial Context <span>// Study Area Overview</span></div>
    <div class="project-map-container" id="map-atlas"></div>
  </div>

  <div class="case-content">

    <div class="phase">
      <div class="phase-label-col"><div class="phase-num">00</div><div class="phase-name">Context</div></div>
      <div class="phase-body">
        <p>Regional planning in BC often requires spatially grounded consultation materials —
        documents that communicate land, resource, and ecosystem information clearly to both technical
        reviewers and non-GIS audiences including <strong>Indigenous rights holders</strong> and executive decision-makers.</p>
        <p>This project called for a comprehensive <strong>bioregional atlas</strong> covering a coastal BC
        study area — a structured series of thematic maps addressing ecological, cultural, and land-use
        dimensions of the region in a consistent, print-ready format.</p>
      </div>
    </div>

    <div class="phase">
      <div class="phase-label-col"><div class="phase-num">01</div><div class="phase-name">Problem</div></div>
      <div class="phase-body">
        <p>Source datasets — watershed boundaries, ecological units, land tenure, resource tenures,
        cultural areas — came from multiple provincial and federal sources with inconsistent projections,
        symbology, and attribute schemas.</p>
        <div class="callout">
          <strong>Core challenge</strong>
          Producing a coherent atlas from fragmented source data required both technical data harmonization
          and a deliberate cartographic design system — so every map in the series felt like part of the
          same document, not a collection of unrelated exports.
        </div>
        <p>The maps needed to serve two distinct audiences simultaneously: technical reviewers who needed
        spatial precision, and community and executive stakeholders who needed clarity and legibility above all.</p>
      </div>
    </div>

    <div class="phase">
      <div class="phase-label-col"><div class="phase-num">02</div><div class="phase-name">Approach</div></div>
      <div class="phase-body">
        <p>Data from provincial, federal, and project-specific sources was consolidated and standardized
        into a <strong>single geodatabase</strong> with consistent projections and attributed fields,
        clipped to a common study area boundary.</p>
        <p>A <strong>map series template</strong> was designed in ArcGIS Pro — establishing a shared page
        layout, coordinate system, scale bar standards, legend formatting, and typography carried across
        all themes. The <strong>ArcGIS Pro Map Series</strong> feature drove each page automatically from
        spatial bookmarks and dynamic text — making updates and extensions fast.</p>
        <p>A <strong>netdown assessment workflow</strong> was also developed — systematically identifying
        overlapping land interests and tenure conflicts across the study area in a reproducible,
        auditable format to support the consultation process.</p>
        <div class="tech-stack">
          <span class="tech-pill">ArcGIS Pro</span>
          <span class="tech-pill">Map Series</span>
          <span class="tech-pill">Spatial Bookmarks</span>
          <span class="tech-pill">Cartographic Design</span>
          <span class="tech-pill">Netdown Analysis</span>
          <span class="tech-pill">BC Data Catalogue</span>
          <span class="tech-pill">Geodatabase Design</span>
        </div>
      </div>
    </div>

    <div class="phase">
      <div class="phase-label-col"><div class="phase-num">03</div><div class="phase-name">Outcome</div></div>
      <div class="phase-body">
        <div class="outcome-stats">
          <div class="outcome-stat"><div class="outcome-value">Multi</div><div class="outcome-label">Theme map series delivered</div></div>
          <div class="outcome-stat"><div class="outcome-value">2x</div><div class="outcome-label">Audiences — technical &amp; exec</div></div>
          <div class="outcome-stat"><div class="outcome-value">↻</div><div class="outcome-label">Updateable template system</div></div>
        </div>
        <p>The completed atlas served as the primary spatial reference document throughout the regional
        planning and consultation process — used in meetings, submitted with technical reports, and
        referenced by decision-makers at the executive level.</p>
        <div class="callout">
          <strong>Design system value</strong>
          Because the atlas was built on a parametric template, adding new themes or updating existing
          ones took a fraction of the time compared to a traditional map production workflow.
        </div>
      </div>
    </div>

  </div>
  <div class="case-nav">
    <a href="airport-ols.html">← Airport OLS & Hazard Tree</a>
    <a href="hydro-terrain.html">Terrain & Hydrology →</a>
  </div>

  <script>
  (function(){
    var m = L.map('map-atlas', { zoomControl: false, attributionControl: false, scrollWheelZoom: false });
    L.tileLayer('https://{s}.basemaps.cartocdn.com/dark_all/{z}/{x}/{y}{r}.png',
      { maxZoom: 19, subdomains: 'abcd' }).addTo(m);
    m.setView([51.5, -127.0], 8);

    var base = { fillOpacity: 0.13, weight: 1.5 };

    // Bioregion boundary
    L.polygon([
      [52.8,-128.5],[53.0,-126.0],[52.5,-124.5],[51.0,-124.8],[50.5,-126.5],[51.2,-128.8]
    ], Object.assign({}, base, { color:'#e85d3a', fillColor:'#e85d3a', weight:2 }))
      .addTo(m).bindPopup('<b>Bioregional Study Area</b><br>Atlas coverage boundary');

    // Watershed sub-units
    [
      [[52.5,-127.8],[52.7,-126.5],[52.2,-126.2],[52.0,-127.5]],
      [[51.8,-127.2],[52.0,-126.0],[51.5,-125.8],[51.3,-127.0]],
      [[52.2,-128.2],[52.5,-127.0],[52.0,-126.8],[51.8,-128.0]],
    ].forEach(function(coords, i){
      L.polygon(coords, Object.assign({}, base, {
        color: '#5b9bd5', fillColor: '#5b9bd5', fillOpacity: 0.15 + i*0.04
      })).addTo(m).bindPopup('<b>Watershed Sub-Unit ' + (i+1) + '</b><br>Hydrological boundary');
    });

    // Resource tenure areas
    [
      [[52.0,-127.5],[52.2,-126.8],[51.9,-126.6],[51.7,-127.3]],
      [[51.4,-126.5],[51.6,-125.8],[51.2,-125.6],[51.0,-126.2]],
    ].forEach(function(coords){
      L.polygon(coords, Object.assign({}, base, {
        color: '#f0a060', fillColor: '#f0a060', dashArray: '5,4'
      })).addTo(m).bindPopup('<b>Resource Tenure Area</b><br>Netdown assessment layer');
    });

    // Cultural/consultation area
    L.polygon([
      [51.6,-128.0],[51.8,-127.0],[51.4,-126.8],[51.2,-127.8]
    ], Object.assign({}, base, {
      color: '#c084d4', fillColor: '#c084d4', fillOpacity: 0.1, dashArray: '3,6'
    })).addTo(m).bindPopup('<b>Consultation Area</b><br>Indigenous planning boundary');

    m.invalidateSize();
  })();
  </script>

</body>
